# Your domain name here (e.g. supa-cloud.example.gov.th)
:80 {
	# Route API traffic to Backend
	handle_path /api/* {
		reverse_proxy backend:8080
	}

	# Route all other traffic to Frontend
	handle {
		reverse_proxy frontend:3000
	}
}
